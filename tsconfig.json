{
  "compilerOptions": {
    "target": "es6",
    "useDefineForClassFields": true,
    "module": "commonjs",
    "outDir": "./dist/",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "noImplicitAny": true,
    "isolatedModules": true,
    /* Linting */
    "strict": true,
    "strictPropertyInitialization": false,
    "sourceMap": false,
    "declaration": false,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "allowJs": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "**/*.spec.ts"
  ]
}